{
  "aiCommand": "hermes",
  "aiSendArgs": ["send", "--to"],
  "aiChatId": null,
  "aiTagPrefix": "@Hermes",
  "reviewSaveDir": "",
  "prFilter": {
    "reviewRequested": true,
    "titleContains": "for review"
  },
  "repoOwner": "",
  "repoName": "",
  "diff": {
    "mode": "since-review",
    "excludeMerges": true,
    "codeFileExtensions": [".pm", ".cgi", ".js", ".jsx", ".ts", ".tsx", ".tpl", ".css", ".scss", ".less", ".json", ".html", ".py", ".rb", ".go", ".java", ".c", ".cpp", ".h", ".hpp", ".sh", ".bash", ".sql", ".yaml", ".yml", ".toml", ".xml", ".md", ".txt"]
  },
  "imageUpload": {
    "enabled": false,
    "provider": "s3",
    "s3Bucket": "",
    "s3Prefix": "",
    "s3Acl": "public-read",
    "awsProfile": "default",
    "awsRegion": "us-east-1"
  },
  "cleanup": {
    "enabled": true,
    "retentionDays": 180,
    "runOnStartup": true
  }
}
